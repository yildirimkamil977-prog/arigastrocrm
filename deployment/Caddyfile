{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode zstd gzip

    # API requests → FastAPI backend
    handle /api/* {
        reverse_proxy backend:8001
    }

    # User-uploaded images (logos, signatures) → shared volume
    handle /uploads/* {
        root * /srv
        file_server
        header Cache-Control "public, max-age=2592000"
    }

    # Everything else → React SPA (static build)
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Gzip-friendly cache for hashed JS/CSS
    @assets path_regexp ^/static/.*\.(js|css|png|jpg|jpeg|svg|woff2?)$
    header @assets Cache-Control "public, max-age=31536000, immutable"
}

# Redirect www → apex
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}
